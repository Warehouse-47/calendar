---
import '../styles/fire-theme.css';

interface Props {
  title?: string;
  sectionMap?: Array<{ href: string; label: string }>;
}

const { title = 'A Sizzling Teppanyaki Affair', sectionMap = [] } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="A cinematic teppanyaki event experience." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="fire-theme">
    <div class="fire-layout-grid">
      {sectionMap.length > 0 && (
        <aside class="fire-sectionmap" aria-label="Page sections">
          <p class="fire-sectionmap__label">On this page</p>
          <nav>
            {sectionMap.map((item) => (
              <a href={item.href}>{item.label}</a>
            ))}
          </nav>
        </aside>
      )}

      <div class="fire-layout-content">
        <slot />
      </div>
    </div>
  </body>
</html>
