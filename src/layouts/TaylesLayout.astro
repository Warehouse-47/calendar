---
import '../styles/tayles.css';
import { buildOrganizationStructuredData, buildWebsiteStructuredData, serializeJsonLd } from '../lib/seo';

interface Props {
  title: string;
  description?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  tone?: 'editorial' | 'quiet' | 'cultural' | 'energetic' | 'warm' | 'fire';
  sectionMap?: Array<{ href: string; label: string }>;
}

const {
  title,
  description = 'Specialized venue and IP event pages for recurring cultural programs, brand collaborations, and calendar-led activations.',
  structuredData,
  tone = 'editorial',
  sectionMap = [],
} = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const siteUrl = String(import.meta.env.PUBLIC_SITE_URL ?? '').trim();
const canonical = siteUrl ? new URL(Astro.url.pathname, siteUrl).toString() : '';
const customStructuredData = Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : [];
const baseStructuredData = siteUrl
  ? [buildOrganizationStructuredData(siteUrl), buildWebsiteStructuredData(siteUrl)]
  : [];
const structuredDataList = [...baseStructuredData, ...customStructuredData];
const navItems = [
  { href: '/tayles', label: 'Calendar' },
  { href: '/tayles/cabinet-of-tayles', label: 'Cabinet' },
  { href: '/tayles/advocate-tayles', label: 'Advocate' },
  { href: '/tayles/tayles-and-tempo', label: 'Tempo' },
  { href: '/tayles/once-upon-a-tayles', label: 'Once Upon' },
  { href: '/tayles/teppanyaki', label: 'Teppanyaki' },
];

function isActiveLink(href: string) {
  if (href === '/tayles') {
    return pathname === '/tayles';
  }

  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0c0b0a" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1" />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`Tayles // ${title}`} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`Tayles // ${title}`} />
    <meta name="twitter:description" content={description} />
    {structuredDataList.map((entry) => (
      <script type="application/ld+json" set:html={serializeJsonLd(entry)}></script>
    ))}
    <title>Tayles // {title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={`tayles-page tayles-tone--${tone}`}>
    <div class="tayles-scene" aria-hidden="true">
      <div class="tayles-scene__orbit tayles-scene__orbit--one"></div>
      <div class="tayles-scene__orbit tayles-scene__orbit--two"></div>
      <div class="tayles-scene__orbit tayles-scene__orbit--three"></div>
      <div class="tayles-scene__mesh"></div>
      <div class="tayles-scene__grain"></div>
    </div>

    <header class="tayles-shell tayles-header">
      <div class="tayles-masthead">
        <a class="tayles-brand" href="/tayles" aria-label="Tayles home">
          <span>Tayles</span>
          <small>The Social Edition</small>
        </a>

        <div class="tayles-edition" aria-label="Edition metadata">
          <span>Edition 04</span>
          <time datetime="2026-04">April 2026</time>
        </div>

        <p class="tayles-header__note">Editorial programming for a recurring third-space culture.</p>

        <nav class="tayles-nav" aria-label="Tayles pages">
          {navItems.map((item) => (
            <a href={item.href} class={isActiveLink(item.href) ? 'is-active' : undefined} aria-current={isActiveLink(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class="tayles-shell tayles-main">
      <div class="tayles-layout-grid">
        {sectionMap.length > 0 && (
          <aside class="tayles-sectionmap" aria-label="Page sections">
            <p class="tayles-sectionmap__label">On this page</p>
            <nav>
              {sectionMap.map((item) => (
                <a href={item.href}>{item.label}</a>
              ))}
            </nav>
          </aside>
        )}

        <div class="tayles-layout-content">
          <slot />
        </div>
      </div>
    </main>
  </body>
</html>
